# Local editor and OS files
.vs/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
.idea/
.DS_Store
Thumbs.db

# Local secrets and machine-specific files
.env
.env.*
*.user
*.suo
*.rsuser
*.userprefs
*.DotSettings.user

# Temporary and generated files
temp/
tmp/
*.tmp
*.log
*.cache
__pycache__/
*.pyc

# Build and dependency outputs that may appear in target projects
bin/
obj/
artifacts/
.artifacts/
node_modules/
coverage/
TestResults/

# Rebuildable distribution archives
packages/*.zip
